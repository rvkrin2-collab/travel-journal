{
  "version": 4,
  "selection": {
    "hero_count": 1,
    "story_min": 7,
    "story_max": 10,
    "story_extension": {
      "enabled": true,
      "absolute_score_floor": 78,
      "max_score_drop_from_hero": 12,
      "require_group_capacity": true
    },
    "prefer_distinct_visual_functions": true,
    "max_story_per_duplicate_group": 1,
