    "forbidden_patterns": [
      "кочев\\w*\\s+(?:образ|уклад|быт)",
      "традицион\\w*\\s+(?:образ|уклад|быт)",
      "культурн\\w*\\s+контекст",
      "гармони\\w*\\s+с\\s+природ",
      "величественн\\w*",
      "уникальн\\w*"
