    "pattern_replacements": {
      "кочев\\w*\\s+(?:образ|уклад|быт)": "юрты и открытое пространство",
      "традицион\\w*\\s+(?:образ|уклад|быт)": "повседневная сцена",
      "культурн\\w*\\s+контекст": "деталь места",
      "гармони\\w*\\s+с\\s+природ": "связь с пейзажем",
      "величественн\\w*": "масштабный",
      "уникальн\\w*": "самостоятельный"
    },
    "forbid_technical_comparison_without_score_difference": true
  },
  "geography": {
    "minimum_confidence_for_named_location": 0.6,
    "keep_low_confidence_frames_unassigned": true
  }
