{
  "version": 6,
  "selection": {
    "hero_count": 1,
    "story_min": 7,
    "story_max": 10,
    "story_extension": {
      "enabled": true,
      "absolute_score_floor": 78,
      "max_score_drop_from_hero": 12,
      "require_group_capacity": true
    },
    "prefer_distinct_visual_functions": true,
    "max_story_per_duplicate_group": 1,
    "max_story_per_duplicate_group_overrides": {
      "лошади": 2,
      "табун": 2
    },
    "max_backstage_per_duplicate_group": 1,
    "skip_score_below": 55,
    "backstage_for_good_secondary_frames": true,
    "skip_for_weak_or_redundant_frames": true,
    "duplicate_group_requires_same_primary_subject": true,
    "duplicate_group_requires_same_visual_function": true,
    "background_only_never_creates_duplicate": true
  },
  "language": {
    "required": "ru",
    "forbidden_phrases": [
      "кочевой образ жизни",
      "традиционный образ жизни",
      "идеально передаёт",
      "величие природы",
      "гармония с природой",
      "живописный",
      "уникальный"
    ],
    "forbidden_patterns": [
      "кочев[а-яё]*\\s+(?:образ|уклад|быт)[а-яё]*",
      "традицион[а-яё]*\\s+(?:образ|уклад|быт)[а-яё]*",
      "культурн[а-яё]*\\s+контекст[а-яё]*",
      "гармони[а-яё]*\\s+с\\s+природ[а-яё]*",
      "величественн[а-яё]*",
      "уникальн[а-яё]*"
    ],
    "pattern_replacements": {
      "кочев[а-яё]*\\s+(?:образ|уклад|быт)[а-яё]*": "местной сцены",
      "традицион[а-яё]*\\s+(?:образ|уклад|быт)[а-яё]*": "повседневной сцены",
      "культурн[а-яё]*\\s+контекст[а-яё]*": "деталь места",
      "гармони[а-яё]*\\s+с\\s+природ[а-яё]*": "связь с пейзажем",
      "величественн[а-яё]*": "масштабный",
      "уникальн[а-яё]*": "самостоятельный"
    },
    "forbid_technical_comparison_without_score_difference": true
  },
  "geography": {
    "minimum_confidence_for_named_location": 0.6,
    "keep_low_confidence_frames_unassigned": true
  }
}
